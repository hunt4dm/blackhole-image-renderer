{
  "name": "blackhole-desktop",
  "private": false,
  "version": "1.0.0",
  "description": "An Electron desktop app for rendering a black hole lensing effect over local images.",
  "author": "Blackhole Image Renderer contributors",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "package": "pnpm run build && electron-builder",
    "package:mac": "pnpm run build && electron-builder --mac",
    "package:win": "pnpm run build && electron-builder --win",
    "package:all": "pnpm run build && electron-builder --mac --win",
    "preview": "vite preview"
  },
  "devDependencies": {
    "typescript": "^5.2.2",
    "vite": "^5.1.6",
    "electron": "^30.0.1",
    "electron-builder": "^24.13.3",
    "vite-plugin-electron": "^0.28.6",
    "vite-plugin-electron-renderer": "^0.14.5"
  },
  "main": "dist-electron/main.js"
}
